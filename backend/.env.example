# Copy to backend/.env and fill in the sections you need.

# --- LLM-per-agent pipeline (POST /check-readiness/pipeline) ---
# Every agent in this pipeline makes its own call to an OpenAI-compatible
# chat completions endpoint. Currently configured for OpenRouter serving
# gpt-oss-120b (free tier). Required - the pipeline cannot run without these.
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
LLM_MODEL=openai/gpt-oss-120b:free

# --- Deterministic ADK pipeline's optional narrator (POST /check-readiness/pipeline/deterministic) ---
# A separate, older pipeline where every readiness decision is deterministic
# Python and only the final narrative paragraph is LLM-generated. Optional -
# without these it still runs end-to-end with a template-based narrative.

# Option A: Google AI Studio (dev)
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=False

# Option B: Vertex AI (prod) - set these instead of GOOGLE_API_KEY
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=
# GOOGLE_GENAI_USE_VERTEXAI=True
