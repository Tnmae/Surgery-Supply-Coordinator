# Copy to backend/.env and fill in the sections you need.

# --- LLM-per-agent ADK pipeline (POST /check-readiness) ---
# Every agent in this pipeline makes its own call to OpenRouter,
# Google AI Studio (Gemini), or a local Ollama server, selected by LLM_PROVIDER.
LLM_PROVIDER=openrouter
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2:latest
OLLAMA_API_KEY=ollama
OLLAMA_TIMEOUT_SECONDS=30
OLLAMA_MAX_TOKENS=256
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
LLM_MODEL=openai/gpt-oss-120b:free
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-2.0-flash
