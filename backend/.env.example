# Copy to backend/.env and fill in the sections you need.
# Set LLM_PROVIDER to one of: openrouter | google | ollama | cloudflare
# The matching credentials below must also be filled in.

# --- CORS ---
# Comma-separated list of allowed frontend origins.
# Add your Vercel frontend URL here once deployed.
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app


LLM_PROVIDER=openrouter

# --- OpenRouter (default) ---
# Free models available: https://openrouter.ai/models?q=free
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
LLM_MODEL=openai/gpt-oss-120b:free

# --- Google AI Studio (Gemini) ---
# Get a key at https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-2.0-flash

# --- Ollama (local) ---
# Run locally: https://ollama.com — pull a model with: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2:latest
OLLAMA_API_KEY=ollama
OLLAMA_TIMEOUT_SECONDS=30
OLLAMA_MAX_TOKENS=256

# --- Cloudflare Workers AI ---
# Dashboard: https://dash.cloudflare.com -> AI -> Workers AI
# API token: Account Settings -> API Tokens -> create with "Workers AI" permission
# Model list: https://developers.cloudflare.com/workers-ai/models/
# Recommended models for structured JSON output:
#   @cf/meta/llama-3.1-8b-instruct          (fast, free tier)
#   @cf/meta/llama-3.3-70b-instruct-fp8-fast (more capable)
#   @cf/mistral/mistral-7b-instruct-v0.1
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_MODEL=@cf/meta/llama-3.1-8b-instruct
